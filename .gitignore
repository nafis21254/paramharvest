# ParamHarvest .gitignore

# Output logs (contains sensitive data)
logs/
*.log
*.json
!logs/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Certificates (may contain private keys)
certs/
*.pem
*.cer
*.crt
*.key
!scripts/install_cert.sh

# PID files
*.pid

# Test outputs
test_output/
.pytest_cache/
.coverage
htmlcov/
